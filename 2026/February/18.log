lab=# INSERT INTO users (email, country, created_at, is_active)
SELECT
    'user' || gs || '@example.com',
    (ARRAY['IN','US','UK','DE','FR'])[floor(random()*5)+1],
    NOW() - (random() * INTERVAL '365 days'),
    random() > 0.5
FROM generate_series(1, 5000000) gs;
^C
